# Donut AI - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Groq Configuration
# ============================================
# Get your API key from https://console.groq.com
# REQUIRED for LLM chat completions and TTS (voice synthesis)
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# REQUIRED: Supabase Configuration
# ============================================
# Get these from your Supabase project settings
# REQUIRED for database operations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# ============================================
# LLM Settings
# ============================================
LLM_MODEL=llama-3.3-70b-versatile
INTENT_MODEL=llama-3.1-8b-instant

# ============================================
# Server Settings
# ============================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# ============================================
# Voice Services (Optional)
# ============================================

# ElevenLabs API Key (10k free chars/month)
# Get from https://elevenlabs.io
ELEVENLABS_API_KEY=

# xAI/Grok Configuration (for web search)
# Get from https://x.ai
XAI_API_KEY=
XAI_MODEL=grok-2-mini

# TTS/STT Provider Priority (comma-separated fallback order)
# Options: groq, elevenlabs, xai, browser
TTS_PROVIDER_PRIORITY=groq,elevenlabs,xai,browser
STT_PROVIDER_PRIORITY=groq,elevenlabs,xai,browser

# Primary TTS Provider
TTS_PROVIDER=groq

# ============================================
# Authentication
# ============================================
JWT_SECRET=change_me_to_random_string
ADMIN_PASSPHRASE=donut-admin

# ============================================
# Optional Integrations
# ============================================

# Google APIs (for Gmail/Calendar integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# OpenAI (optional - for additional TTS/STT)
OPENAI_API_KEY=

# ============================================
# Receptionist Settings
# ============================================
BUSINESS_NAME=Donut Receptionist
WORKING_HOURS_START=9
WORKING_HOURS_END=17
APPOINTMENT_SLOT_DURATION=30
